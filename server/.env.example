# En producción ponga NODE_ENV=production. Activa el modo estricto:
# el servidor NO arranca con un JWT_SECRET inseguro y CORS exige allowlist.
NODE_ENV=development
PORT=4000

# Origen(es) permitido(s) por CORS. Admite varias URLs separadas por comas
# (ej. dominio de producción + preview de Netlify).
CLIENT_URL=http://localhost:5173

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=senaliza

# Seguridad
# GENERE un secreto único y fuerte (>=32 chars). Nunca deje el placeholder:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Con NODE_ENV=production el servidor se niega a arrancar si es inseguro.
JWT_SECRET=cambie_este_valor_por_uno_seguro
JWT_EXPIRES=8h

# Correo SMTP (Hostinger). Lo usan el formulario de contacto Y el aviso de
# nuevas cotizaciones. Complete con su cuenta de correo de Hostinger.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=tu-correo@tudominio.com
SMTP_PASS=tu_contrasena_de_correo
# Destino de los mensajes del formulario de contacto (opcional; por defecto = SMTP_USER)
CONTACT_TO=tu-correo@tudominio.com
# Destino de las cotizaciones (opcional; por defecto = CONTACT_TO, y si no, SMTP_USER)
COTIZACION_TO=tu-correo@tudominio.com
